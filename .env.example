# ---------------------------------------------------------------------------
# voice-agent — environment template. Copy to .env locally; on Railway set
# each of these in Project → Variables.
# ---------------------------------------------------------------------------

# HTTP port. Railway injects this automatically; locally defaults to 3100
# so it doesn't clash with claude-agent on 3000.
PORT=3100

# --- Supabase (same project as claude-agent) -------------------------------
SUPABASE_URL=https://pdberqkgefintebfkvkm.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# --- Telnyx ----------------------------------------------------------------
# REST API key — from Telnyx Mission Control → API Keys. Used to issue
# answer / speak / hangup / streaming_start / transfer commands.
TELNYX_API_KEY=your-telnyx-api-key

# Public key for verifying webhook signatures. From Telnyx Mission
# Control → Auth → Public Key (Ed25519). Required in production.
TELNYX_PUBLIC_KEY=your-telnyx-ed25519-public-key

# --- OpenAI (Phase 2 onwards) ---------------------------------------------
# Same key as claude-agent — Realtime API uses it.
OPENAI_API_KEY=your-openai-api-key
OPENAI_REALTIME_MODEL=gpt-4o-realtime-preview-2024-12-17

# --- Bridge to claude-agent (Phase 3 onwards) ------------------------------
# Voice agent reuses claude-agent's booking HTTP routes instead of
# re-implementing Optima / Google Calendar logic.
BOT_API_URL=https://claude-agent-production.up.railway.app
BOT_API_KEY=your-claude-agent-api-key

# --- Optional --------------------------------------------------------------
# Public hostname of THIS service. Telnyx Media Streaming needs a wss://
# URL it can dial back into; we build it from this. Railway shows the
# hostname under Settings → Domains. Example: voice-agent-production.up.railway.app
PUBLIC_HOSTNAME=voice-agent-production-f9a4.up.railway.app
